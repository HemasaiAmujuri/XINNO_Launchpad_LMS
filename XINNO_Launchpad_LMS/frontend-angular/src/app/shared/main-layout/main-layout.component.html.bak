<div class="min-h-screen bg-white">
  <div class="flex h-screen overflow-hidden">
    <!-- Mobile Menu Button -->
    <button (click)="toggleMobileSidebar()" class="lg:hidden fixed bottom-6 right-6 z-50 w-14 h-14 bg-blue-600 text-white rounded-full shadow-2xl flex items-center justify-center hover:bg-blue-700 transition-all">
      <i class="bi bi-list text-2xl"></i>
    </button>

    <!-- Sidebar Overlay for Mobile -->
    <div *ngIf="isMobileSidebarOpen" (click)="toggleMobileSidebar()" class="lg:hidden fixed inset-0 bg-black/50 z-40"></div>

    <!-- Sidebar - Responsive -->
    <aside 
      [class.translate-x-0]="isMobileSidebarOpen"
      class="w-60 bg-white shadow-lg flex-shrink-0 overflow-y-auto border-r border-gray-200 fixed lg:static inset-y-0 left-0 z-40 transform -translate-x-full lg:translate-x-0 transition-transform duration-300">
      <div class="p-4">
        <!-- User Profile -->
        <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-200">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-blue-700 text-white flex items-center justify-center font-bold text-base shadow-md border border-blue-400">
            {{ currentUser?.name?.charAt(0) || 'A' }}
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-sm text-gray-900 truncate">{{ currentUser?.name || 'Alice' }}</div>
            <div class="text-xs text-blue-600 uppercase">{{ currentUser?.role || 'STUDENT' }}</div>
          </div>
        </div>

        <!-- Navigation Links -->
        <nav class="space-y-1">
          <a routerLink="/dashboard" (click)="closeMobileSidebar()" routerLinkActive="bg-blue-600 text-white border border-blue-400" [routerLinkActiveOptions]="{exact: true}" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 hover:text-gray-900 hover:border hover:border-blue-500 transition-all duration-200">
            <i class="bi bi-house-door text-base text-blue-400"></i>
            <span class="font-medium text-sm">Home</span>
          </a>
          
          <a routerLink="/assessments" (click)="closeMobileSidebar()" routerLinkActive="bg-blue-600 text-white border border-blue-400" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 hover:text-gray-900 hover:border hover:border-blue-500 transition-all duration-200">
            <i class="bi bi-journal-check text-base text-blue-400"></i>
            <span class="font-medium text-sm">Assessments</span>
          </a>
          
          <a routerLink="/projects" (click)="closeMobileSidebar()" routerLinkActive="bg-blue-600 text-white border border-blue-400" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 hover:text-gray-900 hover:border hover:border-blue-500 transition-all duration-200">
            <i class="bi bi-kanban text-base text-blue-400"></i>
            <span class="font-medium text-sm">Projects</span>
          </a>
          
          <a *ngIf="currentUser?.role !== 'ADMIN' && currentUser?.role !== 'TRAINER'" routerLink="/my-feedbacks" (click)="closeMobileSidebar()" routerLinkActive="bg-blue-600 text-white border border-blue-400" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 hover:text-gray-900 hover:border hover:border-blue-500 transition-all duration-200">
            <i class="bi bi-star text-base text-purple-400"></i>
            <span class="font-medium text-sm">My Feedbacks</span>
          </a>
          
          <a *ngIf="currentUser?.role === 'ADMIN' || currentUser?.role === 'TRAINER'" routerLink="/admin" (click)="closeMobileSidebar()" routerLinkActive="bg-blue-600 text-white border border-blue-400" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 hover:text-gray-900 hover:border hover:border-blue-500 transition-all duration-200">
            <i class="bi bi-gear text-base text-blue-400"></i>
            <span class="font-medium text-sm">{{ currentUser?.role === 'TRAINER' ? 'Trainer Panel' : 'Admin' }}</span>
          </a>

          <button (click)="logout()" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-red-400 hover:bg-red-100/30 hover:border hover:border-red-500 transition-all duration-200 mt-4">
            <i class="bi bi-box-arrow-right text-base"></i>
            <span class="font-medium text-sm">Logout</span>
          </button>
        </nav>
      </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col overflow-hidden lg:ml-0">
      <!-- Top Navigation Bar -->
      <header class="bg-white shadow-md border-b border-gray-200 z-10">
        <div class="px-4 lg:px-6 py-3 lg:py-4">
          <div class="flex items-center justify-between gap-2 lg:gap-4">
            <!-- Logo/Title for Mobile -->
            <div class="lg:hidden flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-blue-700 text-white flex items-center justify-center font-bold text-sm">
                O
              </div>
              <span class="font-bold text-gray-900 text-sm">OraXinno LMS</span>
            </div>

            <!-- Search - Hidden on small mobile -->
            <div class="hidden sm:flex flex-1 max-w-xl">
              <div class="relative w-full">
                <input 
                  type="text" 
                  placeholder="Search..." 
                  class="w-full pl-10 pr-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all text-sm"
                />
                <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/>
                  </svg>
                </div>
              </div>
            </div>

            <!-- Right Controls -->
            <div class="flex items-center gap-2">
              <!-- Notifications -->
              <button class="relative p-2 rounded-lg hover:bg-gray-100 text-gray-600 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                </svg>
                <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
              </button>

              <!-- User Profile Dropdown -->
              <div class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-gray-100 cursor-pointer transition-all">
                <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-blue-700 text-white rounded-lg flex items-center justify-center font-bold text-sm">
                  {{ currentUser?.name?.charAt(0) || 'A' }}
                </div>
                <div class="hidden md:block">
                  <div class="text-xs font-semibold text-gray-900">{{ currentUser?.name || 'User' }}</div>
                  <div class="text-xs text-gray-500">{{ currentUser?.role || 'STUDENT' }}</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto bg-gray-50 p-4 lg:p-6">
        <router-outlet></router-outlet>
      </main>
    </div>
  </div>
</div>
                <input type="date" [(ngModel)]="dateRange.to" class="text-sm bg-transparent text-gray-700 border-0 outline-none w-32" />
              </div>

              <!-- Dark Mode Toggle -->
              <button (click)="toggleDarkMode()" class="p-2.5 rounded-lg hover:bg-gray-100 text-blue-400 hover:text-blue-300 border border-transparent hover:border-blue-500 transition-all">
                <svg *ngIf="!darkMode" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
                </svg>
                <svg *ngIf="darkMode" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
                </svg>
              </button>

              <!-- User Profile -->
              <div class="relative">
                <button class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-gray-100 border border-transparent hover:border-blue-500 transition-all">
                  <div class="w-9 h-9 bg-gradient-to-br from-blue-500 to-blue-700 text-gray-900 rounded-lg flex items-center justify-center font-bold shadow-md border border-blue-400">
                    {{ currentUser?.name?.charAt(0) || 'S' }}
                  </div>
                </button>
                <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center font-bold border border-red-400">3</span>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- Main Content (Router Outlet) -->
      <main class="flex-1 overflow-y-auto bg-white">
        <div class="p-4 max-w-[1400px] mx-auto">
          <router-outlet></router-outlet>
        </div>
      </main>
    </div>
  </div>
</div>
