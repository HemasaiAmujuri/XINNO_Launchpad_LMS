<!-- Professional Dashboard - Modern Design -->
<div class="min-h-screen bg-black">
  <!-- Breadcrumb -->
  <div class="mb-6">
    <div class="flex items-center gap-2 text-sm text-gray-400">
      <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
      </svg>
      <span class="text-white">Home</span>
      <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
      <span class="text-blue-500 font-medium">Dashboard</span>
    </div>
  </div>

  <!-- Main Grid Layout -->
  <div class="grid grid-cols-12 gap-6">
    
    <!-- Left Column - Stats Cards -->
    <div class="col-span-12 lg:col-span-3 space-y-6">
      <!-- Total Contacts Card -->
      <div class="bg-black rounded-2xl p-5 shadow-lg border-2 border-blue-500 hover:border-blue-400 transition-all">
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm font-medium text-gray-300">Total Contacts</p>
          <button class="text-blue-400 hover:text-blue-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
            </svg>
          </button>
        </div>
        <div class="flex items-end gap-3 mb-3">
          <h2 class="text-3xl font-bold text-white">5,758</h2>
          <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-emerald-900/50 text-emerald-400 border border-emerald-500">+2.57%</span>
        </div>
        <!-- Mini Chart -->
        <div class="h-12 flex items-end gap-1">
          <div class="flex-1 bg-blue-900 rounded-t h-6 border-t-2 border-blue-500"></div>
          <div class="flex-1 bg-blue-800 rounded-t h-8 border-t-2 border-blue-500"></div>
          <div class="flex-1 bg-blue-700 rounded-t h-10 border-t-2 border-blue-500"></div>
          <div class="flex-1 bg-blue-600 rounded-t h-7 border-t-2 border-blue-500"></div>
          <div class="flex-1 bg-blue-500 rounded-t h-12 border-t-2 border-blue-400"></div>
        </div>
        <div class="flex items-center justify-between mt-4 pt-3 border-t border-blue-900">
          <span class="text-xs text-gray-400">Vs last month: 1,195</span>
          <a class="text-blue-400 hover:text-blue-300 cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Tasks Overview Card -->
      <div class="bg-black rounded-2xl p-5 shadow-lg border-2 border-blue-500">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-white">Tasks Overview</h3>
          <span class="text-xs text-gray-400">Tasks Done <span class="font-semibold text-white">25</span></span>
        </div>
        <!-- Progress Bar -->
        <div class="w-full bg-gray-800 rounded-full h-2 mb-4 border border-blue-900">
          <div class="bg-blue-500 h-2 rounded-full" style="width: 65%"></div>
        </div>
        <!-- Task List -->
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded bg-blue-300 border border-blue-400"></div>
            <span class="text-sm text-gray-300">Follow-ups</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded bg-blue-500 border border-blue-600"></div>
            <span class="text-sm text-gray-300">In Progress</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded bg-blue-700 border border-blue-800"></div>
            <span class="text-sm text-gray-300">Pending</span>
          </div>
        </div>
        <!-- Donut Chart Placeholder -->
        <div class="flex justify-center mt-4">
          <div class="relative w-24 h-24">
            <svg class="w-24 h-24 transform -rotate-90" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="14" fill="none" stroke="#1f2937" stroke-width="4"></circle>
              <circle cx="18" cy="18" r="14" fill="none" stroke="#3b82f6" stroke-width="4" stroke-dasharray="60 40" stroke-linecap="round"></circle>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-xl font-bold text-white">15</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Middle Column -->
    <div class="col-span-12 lg:col-span-5 space-y-6">
      <!-- Lead Analytics Card -->
      <div class="bg-black rounded-2xl p-5 shadow-lg border-2 border-blue-500">
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm font-medium text-gray-300">Lead Analytics</p>
          <button class="text-blue-400 hover:text-blue-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
            </svg>
          </button>
        </div>
        <div class="flex items-end gap-3 mb-2">
          <h2 class="text-3xl font-bold text-white">70</h2>
          <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-rose-900/50 text-rose-400 border border-rose-500">-2.57%</span>
        </div>
        <!-- Wave Chart -->
        <div class="h-16 mt-4">
          <svg class="w-full h-full" viewBox="0 0 200 50" preserveAspectRatio="none">
            <path d="M0,40 Q25,20 50,30 T100,25 T150,35 T200,20" fill="none" stroke="#a5b4fc" stroke-width="2" class="dark:stroke-indigo-400"></path>
            <path d="M0,40 Q25,20 50,30 T100,25 T150,35 T200,20 L200,50 L0,50 Z" fill="url(#gradient)" opacity="0.2"></path>
            <defs>
              <linearGradient id="gradient" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#6366f1;stop-opacity:0.3"></stop>
                <stop offset="100%" style="stop-color:#6366f1;stop-opacity:0"></stop>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 text-center">Compared to Last Month</p>
      </div>

      <!-- Active Deals Card -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-700">
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Active Deals</p>
          <button class="text-slate-400 hover:text-slate-600">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
            </svg>
          </button>
        </div>
        <div class="flex items-end gap-3 mb-4">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white">1,249</h2>
          <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">+2.57%</span>
        </div>
        <div class="flex items-center justify-between pt-3 border-t border-slate-100 dark:border-slate-700">
          <span class="text-xs text-slate-500 dark:text-slate-400">Vs last month: 1,195</span>
          <a class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Revenue Card with Chart -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-700">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Revenue</h3>
          <div class="flex items-center gap-1 bg-slate-100 dark:bg-slate-700 rounded-lg p-1">
            <button class="px-3 py-1 text-xs font-medium rounded-md bg-white dark:bg-slate-600 shadow text-slate-900 dark:text-white">Today</button>
            <button class="px-3 py-1 text-xs font-medium text-slate-500 dark:text-slate-400 hover:bg-white dark:hover:bg-slate-600 rounded-md">Week</button>
            <button class="px-3 py-1 text-xs font-medium text-slate-500 dark:text-slate-400 hover:bg-white dark:hover:bg-slate-600 rounded-md">Month</button>
          </div>
        </div>
        <div class="flex items-baseline gap-2 mb-4">
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white">$2,56,054.50</h2>
          <span class="text-sm text-emerald-600 dark:text-emerald-400 font-medium">+20% vs last month</span>
        </div>
        <!-- Bar Chart -->
        <div class="h-40 flex items-end gap-2">
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full bg-indigo-200 dark:bg-indigo-900/50 rounded-t h-16"></div>
            <span class="text-xs text-slate-400">Mon</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full bg-indigo-300 dark:bg-indigo-800/50 rounded-t h-24"></div>
            <span class="text-xs text-slate-400">Tue</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full bg-indigo-400 dark:bg-indigo-700/50 rounded-t h-32"></div>
            <span class="text-xs text-slate-400">Wed</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full bg-indigo-500 dark:bg-indigo-600/50 rounded-t h-20"></div>
            <span class="text-xs text-slate-400">Thu</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full bg-indigo-600 dark:bg-indigo-500 rounded-t h-28"></div>
            <span class="text-xs text-slate-400">Fri</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full bg-indigo-400 dark:bg-indigo-700/50 rounded-t h-36"></div>
            <span class="text-xs text-slate-400">Sat</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full bg-indigo-300 dark:bg-indigo-800/50 rounded-t h-24"></div>
            <span class="text-xs text-slate-400">Sun</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column -->
    <div class="col-span-12 lg:col-span-4 space-y-6">
      <!-- Traffic Sources Card -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-700">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Traffic Sources</h3>
        </div>
        <!-- Donut Chart -->
        <div class="flex justify-center mb-6">
          <div class="relative w-32 h-32">
            <svg class="w-32 h-32 transform -rotate-90" viewBox="0 0 36 36">
              <circle cx="18" cy="18" r="14" fill="none" stroke="#e2e8f0" stroke-width="3" class="dark:stroke-slate-700"></circle>
              <circle cx="18" cy="18" r="14" fill="none" stroke="#6366f1" stroke-width="3" stroke-dasharray="41.5 58.5" stroke-linecap="round"></circle>
              <circle cx="18" cy="18" r="14" fill="none" stroke="#10b981" stroke-width="3" stroke-dasharray="27 73" stroke-dashoffset="-41.5" stroke-linecap="round"></circle>
              <circle cx="18" cy="18" r="14" fill="none" stroke="#8b5cf6" stroke-width="3" stroke-dasharray="18 82" stroke-dashoffset="-68.5" stroke-linecap="round"></circle>
            </svg>
          </div>
        </div>
        <!-- Legend -->
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-indigo-500"></div>
              <span class="text-sm text-slate-600 dark:text-slate-400">Organic Search</span>
            </div>
            <span class="text-sm font-semibold text-slate-900 dark:text-white">41.50%</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
              <span class="text-sm text-slate-600 dark:text-slate-400">Direct Traffic</span>
            </div>
            <span class="text-sm font-semibold text-slate-900 dark:text-white">27%</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-violet-500"></div>
              <span class="text-sm text-slate-600 dark:text-slate-400">Referral Traffic</span>
            </div>
            <span class="text-sm font-semibold text-slate-900 dark:text-white">18%</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-pink-500"></div>
              <span class="text-sm text-slate-600 dark:text-slate-400">Social Media</span>
            </div>
            <span class="text-sm font-semibold text-slate-900 dark:text-white">10.30%</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-amber-500"></div>
              <span class="text-sm text-slate-600 dark:text-slate-400">Email Traffic</span>
            </div>
            <span class="text-sm font-semibold text-slate-900 dark:text-white">3.20%</span>
          </div>
        </div>
        <!-- Annual Report Link -->
        <div class="flex items-center justify-between mt-6 pt-4 border-t border-slate-100 dark:border-slate-700">
          <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Annual report</span>
          <a class="flex items-center gap-1 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            Download
          </a>
        </div>
      </div>

      <!-- Total Earning Card - Indigo Background -->
      <div class="bg-gradient-to-br from-indigo-600 to-indigo-700 dark:from-indigo-700 dark:to-indigo-800 rounded-2xl p-5 shadow-lg text-white">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-medium text-indigo-200">Total Earning</h3>
          <button class="text-indigo-200 hover:text-white">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
            </svg>
          </button>
        </div>
        <div class="text-center mb-4">
          <h2 class="text-4xl font-bold">$5.7m</h2>
          <p class="text-indigo-200 text-sm mt-1">673 Orders</p>
        </div>
        <div class="grid grid-cols-2 gap-4 mt-6">
          <div class="bg-white/10 rounded-xl p-3 text-center">
            <p class="text-2xl font-bold">$2.78m</p>
            <p class="text-xs text-indigo-200 mt-1">245 Pickups</p>
          </div>
          <div class="bg-white/10 rounded-xl p-3 text-center">
            <p class="text-2xl font-bold">$65,823</p>
            <p class="text-xs text-indigo-200 mt-1">120 Shipment</p>
          </div>
        </div>
        <!-- Orders Status -->
        <div class="mt-6">
          <h4 class="text-sm font-medium text-indigo-200 mb-3">Orders Status</h4>
          <div class="w-full bg-indigo-500/30 rounded-full h-2 mb-4">
            <div class="flex h-2 rounded-full overflow-hidden">
              <div class="bg-white" style="width: 70%"></div>
              <div class="bg-indigo-300" style="width: 25%"></div>
              <div class="bg-indigo-400" style="width: 5%"></div>
            </div>
          </div>
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-white"></div>
                <span class="text-xs text-indigo-200">Paid</span>
              </div>
              <span class="text-xs font-semibold">70%</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-indigo-300"></div>
                <span class="text-xs text-indigo-200">Cancelled</span>
              </div>
              <span class="text-xs font-semibold">25%</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-indigo-400"></div>
                <span class="text-xs text-indigo-200">Refunded</span>
              </div>
              <span class="text-xs font-semibold">5%</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Row - Full Width Cards -->
    <div class="col-span-12 grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Retention Rate Card -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-700">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Retention Rate</h3>
            <div class="flex items-baseline gap-2 mt-1">
              <span class="text-3xl font-bold text-slate-900 dark:text-white">92%</span>
              <span class="text-sm text-emerald-600 dark:text-emerald-400 font-medium">+15% vs last month</span>
            </div>
          </div>
          <button class="text-slate-400 hover:text-slate-600">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
            </svg>
          </button>
        </div>
        <!-- Bar Chart -->
        <div class="h-32 flex items-end gap-3 mt-6">
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full flex gap-0.5">
              <div class="flex-1 bg-indigo-300 dark:bg-indigo-700 rounded-t h-16"></div>
              <div class="flex-1 bg-indigo-500 dark:bg-indigo-500 rounded-t h-20"></div>
            </div>
            <span class="text-xs text-slate-400">Jan</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full flex gap-0.5">
              <div class="flex-1 bg-indigo-300 dark:bg-indigo-700 rounded-t h-20"></div>
              <div class="flex-1 bg-indigo-500 dark:bg-indigo-500 rounded-t h-28"></div>
            </div>
            <span class="text-xs text-slate-400">Feb</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full flex gap-0.5">
              <div class="flex-1 bg-indigo-300 dark:bg-indigo-700 rounded-t h-12"></div>
              <div class="flex-1 bg-indigo-500 dark:bg-indigo-500 rounded-t h-16"></div>
            </div>
            <span class="text-xs text-slate-400">Mar</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full flex gap-0.5">
              <div class="flex-1 bg-indigo-300 dark:bg-indigo-700 rounded-t h-24"></div>
              <div class="flex-1 bg-indigo-500 dark:bg-indigo-500 rounded-t h-28"></div>
            </div>
            <span class="text-xs text-slate-400">Apr</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full flex gap-0.5">
              <div class="flex-1 bg-indigo-300 dark:bg-indigo-700 rounded-t h-20"></div>
              <div class="flex-1 bg-indigo-500 dark:bg-indigo-500 rounded-t h-24"></div>
            </div>
            <span class="text-xs text-slate-400">May</span>
          </div>
          <div class="flex-1 flex flex-col items-center gap-1">
            <div class="w-full flex gap-0.5">
              <div class="flex-1 bg-indigo-300 dark:bg-indigo-700 rounded-t h-28"></div>
              <div class="flex-1 bg-indigo-500 dark:bg-indigo-500 rounded-t h-32"></div>
            </div>
            <span class="text-xs text-slate-400">Jun</span>
          </div>
        </div>
      </div>

      <!-- Order By Time Card -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 shadow-sm border border-slate-200 dark:border-slate-700">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Order By Time</h3>
          <button class="text-slate-400 hover:text-slate-600">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path>
            </svg>
          </button>
        </div>
        <!-- Heatmap Grid -->
        <div class="grid grid-cols-8 gap-1">
          <div class="text-xs text-slate-400 text-right pr-2">4pm</div>
          <div class="h-6 rounded bg-indigo-100 dark:bg-indigo-900/30"></div>
          <div class="h-6 rounded bg-indigo-200 dark:bg-indigo-800/40"></div>
          <div class="h-6 rounded bg-indigo-300 dark:bg-indigo-700/50"></div>
