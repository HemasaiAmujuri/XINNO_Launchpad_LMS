generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String
  name                String
  role                UserRole
  courseType          CourseType?
  batchName           String?
  rollNumber          String?
  isActive            Boolean              @default(true)
  canGiveFeedback     Boolean              @default(false) // Admin can enable/disable feedback permission for trainers
  resetToken          String?
  resetTokenExpiry    DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  courseLevel         CourseLevel?
  assessmentAttempts  AssessmentAttempt[]
  feedbackReviews     FeedbackReview[]
  feedbackSubmissions FeedbackSubmission[]
  mentorProjects      Project[]            @relation("MentorProjects")
  projects            Project[]            @relation("StudentProjects")
  feedbackGiven       DirectFeedback[]     @relation("FeedbackGiven")
  feedbackReceived    DirectFeedback[]     @relation("FeedbackReceived")

  @@index([email])
  @@index([role])
  @@index([rollNumber])
}

model Assessment {
  id               String              @id @default(uuid())
  title            String
  description      String?
  courseType       CourseType
  totalMarks       Int
  passingMarks     Int
  timeLimitMinutes Int                 @default(15)
  isPublished      Boolean             @default(false)
  allowReAttempt   Boolean             @default(false)
  createdBy        String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  batchName        String?
  instructions     String?             @db.Text
  showResults      Boolean             @default(true)
  accessPin        String?
  attempts         AssessmentAttempt[]
  questions        Question[]

  @@index([courseType])
  @@index([isPublished])
}

model Question {
  id              String          @id @default(uuid())
  assessmentId    String
  questionText    String          @db.Text
  questionType    QuestionType
  marks           Int
  difficultyLevel DifficultyLevel
  orderIndex      Int
  options         Json?
  correctAnswer   String?
  characterLimit  Int?
  sampleAnswer    String?         @db.Text
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  answers         Answer[]
  assessment      Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([questionType])
}

model AssessmentAttempt {
  id               String           @id @default(uuid())
  assessmentId     String
  studentId        String
  status           AssessmentStatus @default(NOT_STARTED)
  startedAt        DateTime?
  submittedAt      DateTime?
  timeSpentSeconds Int              @default(0)
  totalMarks       Int              @default(0)
  obtainedMarks    Float            @default(0)
  isPassed         Boolean          @default(false)
  isAutoSubmitted  Boolean          @default(false)
  reviewedBy       String?
  reviewedAt       DateTime?
  remarks          String?          @db.Text
  answers          Answer[]
  assessment       Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student          User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([status])
}

model Answer {
  id            String            @id @default(uuid())
  attemptId     String
  questionId    String
  answerText    String            @db.Text
  isCorrect     Boolean?
  marksAwarded  Float             @default(0)
  autoEvaluated Boolean           @default(false)
  evaluatedBy   String?
  evaluatedAt   DateTime?
  feedback      String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  attempt       AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model Project {
  id                String                 @id @default(uuid())
  title             String
  description       String                 @db.Text
  studentId         String
  mentorId          String
  courseType        CourseType
  startDate         DateTime
  endDate           DateTime
  currentStage      ProjectStage           @default(PROBLEM_STATEMENT)
  completionPercent Float                  @default(0)
  isCompleted       Boolean                @default(false)
  finalGrade        String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  mentor            User                   @relation("MentorProjects", fields: [mentorId], references: [id])
  student           User                   @relation("StudentProjects", fields: [studentId], references: [id], onDelete: Cascade)
  documents         ProjectDocument[]
  stageProgress     ProjectStageProgress[]

  @@index([studentId])
  @@index([mentorId])
  @@index([currentStage])
}

model ProjectStageProgress {
  id             String       @id @default(uuid())
  projectId      String
  stage          ProjectStage
  status         StageStatus  @default(PENDING)
  startDate      DateTime?
  completionDate DateTime?
  mentorRemarks  String?      @db.Text
  studentNotes   String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  approvedAt     DateTime?
  approvedBy     String?
  dailyProgress  Json?
  isApproved     Boolean      @default(false)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stage])
  @@index([projectId])
}

model ProjectDocument {
  id         String        @id @default(uuid())
  projectId  String
  title      String
  fileUrl    String
  fileType   String
  uploadedBy String
  stage      ProjectStage?
  createdAt  DateTime      @default(now())
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model FeedbackForm {
  id          String               @id @default(uuid())
  title       String
  description String?
  forRole     UserRole
  courseType  CourseType?
  isActive    Boolean              @default(true)
  createdBy   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  questions   FeedbackQuestion[]
  submissions FeedbackSubmission[]

  @@index([forRole])
  @@index([isActive])
}

model FeedbackQuestion {
  id           String             @id @default(uuid())
  formId       String
  questionText String             @db.Text
  questionType String
  isRequired   Boolean            @default(true)
  options      Json?
  orderIndex   Int
  createdAt    DateTime           @default(now())
  form         FeedbackForm       @relation(fields: [formId], references: [id], onDelete: Cascade)
  responses    FeedbackResponse[]

  @@index([formId])
}

model FeedbackSubmission {
  id          String             @id @default(uuid())
  formId      String
  submittedBy String
  submittedAt DateTime           @default(now())
  responses   FeedbackResponse[]
  reviews     FeedbackReview[]
  form        FeedbackForm       @relation(fields: [formId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [submittedBy], references: [id], onDelete: Cascade)

  @@unique([formId, submittedBy])
  @@index([formId])
  @@index([submittedBy])
}

model FeedbackResponse {
  id           String             @id @default(uuid())
  submissionId String
  questionId   String
  responseText String             @db.Text
  question     FeedbackQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  submission   FeedbackSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
}

model FeedbackReview {
  id           String             @id @default(uuid())
  submissionId String
  reviewedBy   String
  rating       Int?
  comments     String?            @db.Text
  reviewedAt   DateTime           @default(now())

  reviewer     User               @relation(fields: [reviewedBy], references: [id])
  submission   FeedbackSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([reviewedBy])
}

model DirectFeedback {
  id          String   @id @default(uuid())
  givenBy     String
  givenTo     String
  marks       Float?
  maxMarks    Float?
  comments    String   @db.Text
  category    String   @default("GENERAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  giver       User     @relation("FeedbackGiven", fields: [givenBy], references: [id], onDelete: Cascade)
  recipient   User     @relation("FeedbackReceived", fields: [givenTo], references: [id], onDelete: Cascade)

  @@index([givenBy])
  @@index([givenTo])
  @@index([createdAt])
}

enum UserRole {
  ADMIN
  TRAINER
  REVIEWER
  STUDENT
}

enum CourseType {
  CRT
  ORACLE
  EPM
  OIC
  FULL_STACK
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MCQ
  DESCRIPTIVE
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum ProjectStage {
  PROBLEM_STATEMENT
  REQUIREMENT_ANALYSIS
  DESIGN_ARCHITECTURE
  DEVELOPMENT
  TESTING_VALIDATION
  DOCUMENTATION
  FINAL_DEMO_REVIEW
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum AssessmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}
