{
  "name": "oraxinno-lms-backend",
  "version": "1.0.0",
  "description": "OraXinno LMS Backend - Next.js + Prisma",
  "scripts": {
  "dev": "next dev -p 3001",
  "build": "prisma generate && prisma migrate deploy && next build",
  "start": "next start -p 3001",
  "lint": "next lint",

  "db:generate": "prisma generate",
  "db:migrate": "prisma migrate dev",
  "db:deploy": "prisma migrate deploy",
  "db:seed": "tsx prisma/seed.ts",
  "db:reset": "prisma migrate reset --force",
  "db:studio": "prisma studio"
},
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@types/nodemailer": "^7.0.9",
    "bcryptjs": "^2.4.3",
    "cookie": "^0.6.0",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "next": "14.1.0",
    "nodemailer": "^7.0.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
